<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Category Colors (slightly darker for light bg contrast) -->
    <Color x:Key="CatFeedColor">#167060</Color>
    <Color x:Key="CatBowelColor">#9A6A10</Color>
    <Color x:Key="CatHygieneColor">#285088</Color>
    <Color x:Key="CatBodyColor">#604080</Color>
    <Color x:Key="CatHealthColor">#903030</Color>
    <Color x:Key="CatEtcColor">#405058</Color>
    <Color x:Key="CatSystemColor">#807060</Color>

    <!-- 소변/대변 구분 (배변 하위 색상) -->
    <Color x:Key="CatUrineColor">#B8A030</Color>
    <Color x:Key="CatStoolColor">#783C10</Color>

    <!-- Background Colors (눈 편한 톤 — 밝기 한단계 더 낮춤) -->
    <Color x:Key="BgDarkColor">#B8BEC8</Color>
    <Color x:Key="BgCardColor">#C8CDD6</Color>
    <Color x:Key="BgSidebarColor">#B0B6C0</Color>
    <Color x:Key="BgInputColor">#C0C5D0</Color>

    <!-- UI Colors -->
    <Color x:Key="BorderColor">#9098A8</Color>
    <Color x:Key="TextLightColor">#1A1F2E</Color>
    <Color x:Key="TextMidColor">#5A6A8A</Color>
    <Color x:Key="WhiteColor">#FFFFFF</Color>

    <!-- Category Brushes -->
    <SolidColorBrush x:Key="CatFeedBrush" Color="{StaticResource CatFeedColor}"/>
    <SolidColorBrush x:Key="CatBowelBrush" Color="{StaticResource CatBowelColor}"/>
    <SolidColorBrush x:Key="CatHygieneBrush" Color="{StaticResource CatHygieneColor}"/>
    <SolidColorBrush x:Key="CatBodyBrush" Color="{StaticResource CatBodyColor}"/>
    <SolidColorBrush x:Key="CatHealthBrush" Color="{StaticResource CatHealthColor}"/>
    <SolidColorBrush x:Key="CatEtcBrush" Color="{StaticResource CatEtcColor}"/>
    <SolidColorBrush x:Key="CatSystemBrush" Color="{StaticResource CatSystemColor}"/>

    <SolidColorBrush x:Key="CatUrineBrush" Color="{StaticResource CatUrineColor}"/>
    <SolidColorBrush x:Key="CatStoolBrush" Color="{StaticResource CatStoolColor}"/>

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDarkColor}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgSidebarBrush" Color="{StaticResource BgSidebarColor}"/>
    <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource BgInputColor}"/>

    <!-- UI Brushes -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource TextLightColor}"/>
    <SolidColorBrush x:Key="TextMidBrush" Color="{StaticResource TextMidColor}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource WhiteColor}"/>

    <!-- Title Bar / Scoreboard / Sidebar Brushes -->
    <SolidColorBrush x:Key="BgTitleBarBrush" Color="#A8B0BC"/>
    <SolidColorBrush x:Key="BgScoreboardBrush" Color="#B8BEC8"/>
    <SolidColorBrush x:Key="ProgressBarBgBrush" Color="#A0A8B4"/>
    <SolidColorBrush x:Key="BgSidebarHoverBrush" Color="#A8B0C0"/>
    <SolidColorBrush x:Key="BgSidebarActiveBrush" Color="#A0A8B8"/>

    <!-- DataGrid 선택 행 -->
    <SolidColorBrush x:Key="DataGridSelectedBrush" Color="#A0C4E8"/>
    <SolidColorBrush x:Key="DataGridHoverBrush" Color="#B0D0E8"/>
    <SolidColorBrush x:Key="DataGridSelectedBorderBrush" Color="#3070B0"/>

    <!-- 카테고리 선택 배경 tint (Light) -->
    <SolidColorBrush x:Key="CatFeedTintBrush" Color="#A8D0C8"/>
    <SolidColorBrush x:Key="CatBowelTintBrush" Color="#D0C8A0"/>
    <SolidColorBrush x:Key="CatHygieneTintBrush" Color="#A8B8D4"/>
    <SolidColorBrush x:Key="CatBodyTintBrush" Color="#C0B0D4"/>
    <SolidColorBrush x:Key="CatHealthTintBrush" Color="#D4A8A8"/>
    <SolidColorBrush x:Key="CatEtcTintBrush" Color="#B8C0C8"/>

</ResourceDictionary>

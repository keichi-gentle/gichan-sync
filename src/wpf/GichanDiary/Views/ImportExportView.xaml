<UserControl x:Class="GichanDiary.Views.ImportExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GichanDiary.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ImportExportViewModel, IsDesignTimeCreatable=False}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
        <StackPanel Margin="16,12">

            <!-- File Info Card -->
            <Border Style="{DynamicResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Path Data="{DynamicResource IconExcel}" Stroke="{DynamicResource CatSystemBrush}" StrokeThickness="1.5" Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0"/>
                        <TextBlock Text="현재 DB 동기화 정보" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource CatSystemBrush}"/>
                    </StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="DB 경로" FontSize="19" Foreground="{DynamicResource TextMidBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentFilePath}" FontSize="19" FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="총 레코드" FontSize="19" Foreground="{DynamicResource TextMidBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding TotalRecords, StringFormat={}{0}건}" FontSize="19" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="마지막 갱신" FontSize="19" Foreground="{DynamicResource TextMidBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding LastSaved}" FontSize="19" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Import / Export cards side by side -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Import Card -->
                <Border Grid.Column="0" Style="{DynamicResource CardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Data="{DynamicResource IconExcel}" Stroke="{DynamicResource CatSystemBrush}" StrokeThickness="1.5" Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="가져오기 (Import)" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource CatSystemBrush}"/>
                        </StackPanel>

                        <!-- 가져오기 모드 — 한 줄 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
                            <TextBlock Text="모드:" FontSize="19" Foreground="{DynamicResource TextMidBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <RadioButton Content="덮어쓰기" IsChecked="{Binding ImportOverwrite}"
                                         FontSize="19" Foreground="{DynamicResource TextLightBrush}"
                                         VerticalContentAlignment="Center" Margin="0,0,16,0"
                                         ToolTipService.ShowDuration="60000">
                                <RadioButton.ToolTip>
                                    <ToolTip Content="기존 데이터를 모두 삭제하고 선택한 파일의 데이터로 교체합니다."
                                             StaysOpen="True" Placement="Bottom"/>
                                </RadioButton.ToolTip>
                            </RadioButton>
                            <RadioButton Content="병합" FontSize="19"
                                         Foreground="{DynamicResource TextLightBrush}"
                                         VerticalContentAlignment="Center"
                                         ToolTipService.ShowDuration="60000">
                                <RadioButton.ToolTip>
                                    <ToolTip Content="기존 데이터를 유지하면서 선택한 파일의 데이터를 추가합니다. 날짜순으로 자동 정렬됩니다."
                                             StaysOpen="True" Placement="Bottom"/>
                                </RadioButton.ToolTip>
                            </RadioButton>
                        </StackPanel>

                        <Button Content="Excel 파일 가져오기" Command="{Binding ImportCommand}"
                                Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Stretch"
                                Height="48" FontSize="19"
                                ToolTip="실행하면 선택한 파일의 데이터가 현재 DB에 바로 반영됩니다."
                                ToolTipService.ShowDuration="60000"/>
                    </StackPanel>
                </Border>

                <!-- Export Card -->
                <Border Grid.Column="2" Style="{DynamicResource CardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Data="{DynamicResource IconSave}" Stroke="{DynamicResource CatSystemBrush}" StrokeThickness="1.5" Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="내보내기 (Export)" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource CatSystemBrush}"/>
                        </StackPanel>

                        <TextBlock Text="현재 데이터를 새 Excel 파일로 내보냅니다." FontSize="19"
                                   Foreground="{DynamicResource TextMidBrush}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                        <Button Content="Excel 파일로 내보내기" Command="{Binding ExportCommand}"
                                Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Stretch"
                                Height="48" FontSize="19"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Backup: 수동 + 자동 나란히 -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 수동 백업 -->
                <Border Grid.Column="0" Style="{DynamicResource CardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Data="{DynamicResource IconSave}" Stroke="{DynamicResource CatSystemBrush}" StrokeThickness="1.5" Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="수동 백업" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource CatSystemBrush}"/>
                        </StackPanel>
                        <TextBlock Text="현재 DB의 백업을 원하는 위치에 저장합니다." FontSize="19"
                                   Foreground="{DynamicResource TextMidBrush}" Margin="0,0,0,12"/>
                        <Button Content="백업 생성" Command="{Binding CreateBackupCommand}"
                                Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Left"
                                MinWidth="120" Height="40" FontSize="19" Background="{DynamicResource CatSystemBrush}"/>
                    </StackPanel>
                </Border>

                <!-- 자동 백업 설정 -->
                <Border Grid.Column="2" Style="{DynamicResource CardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Path Data="{DynamicResource IconSettings}" Stroke="{DynamicResource CatSystemBrush}" StrokeThickness="1.5" Width="20" Height="20" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="자동 백업 설정" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource CatSystemBrush}"/>
                        </StackPanel>

                        <!-- ON/OFF -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="자동 백업:" FontSize="19" Foreground="{DynamicResource TextMidBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <CheckBox IsChecked="{Binding AutoBackupEnabled}" Content="사용"
                                      FontSize="19" Foreground="{DynamicResource TextLightBrush}"
                                      VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <!-- 백업 시간 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="시점:" FontSize="19" Foreground="{DynamicResource TextMidBrush}"
                                       VerticalAlignment="Center" Width="60"/>
                            <TextBlock Text="앱 시작 시 (하루 1회)" FontSize="19"
                                       Foreground="{DynamicResource TextLightBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 백업 폴더 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="폴더:" FontSize="19" Foreground="{DynamicResource TextMidBrush}"
                                       VerticalAlignment="Center" Width="60"/>
                            <TextBox Text="{Binding AutoBackupFolder, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="19" Width="475" VerticalContentAlignment="Center"/>
                            <Button Content="..." Command="{Binding BrowseBackupFolderCommand}"
                                    Width="36" Height="36" FontSize="19" Margin="6,0,0,0"
                                    Foreground="{DynamicResource TextLightBrush}" Background="{DynamicResource BgInputBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" Cursor="Hand"/>
                        </StackPanel>

                        <!-- 파일명 양식 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="양식:" FontSize="19" Foreground="{DynamicResource TextMidBrush}"
                                       VerticalAlignment="Center" Width="60"/>
                            <TextBox Text="{Binding AutoBackupFilePattern, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="19" Width="475" VerticalContentAlignment="Center"
                                     ToolTipService.ShowDuration="120000">
                                <TextBox.ToolTip>
                                    <ToolTip Content="{}{name}=원본파일명, {yyyyMMdd_HHmmss}=날짜시간, {yyyyMMdd}=날짜만&#10;예: {name}_backup_{yyyyMMdd_HHmmss}"
                                             StaysOpen="True"/>
                                </TextBox.ToolTip>
                            </TextBox>
                        </StackPanel>

                        <!-- 저장 버튼 -->
                        <Button Content="설정 저장" Command="{Binding SaveAutoBackupSettingsCommand}"
                                Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Left"
                                MinWidth="120" Height="40" FontSize="19" Background="{DynamicResource CatSystemBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status message -->
            <Border Style="{DynamicResource CardBorder}" Margin="0,0,0,0" Padding="12,8">
                <TextBlock Text="{Binding StatusMessage}" FontSize="19"
                           Foreground="{DynamicResource CatFeedBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

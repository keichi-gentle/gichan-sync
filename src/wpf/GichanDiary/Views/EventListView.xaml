<UserControl x:Class="GichanDiary.Views.EventListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:GichanDiary.ViewModels"
             xmlns:conv="clr-namespace:GichanDiary.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:EventListViewModel, IsDesignTimeCreatable=False}">

    <UserControl.Resources>
        <conv:CategoryToColorConverter x:Key="CategoryToColor"/>
        <conv:DetailColorConverter x:Key="DetailColor"/>
        <conv:TimeSpanToStringConverter x:Key="TimeSpanToString"/>
    </UserControl.Resources>

    <DockPanel Margin="16,12">
        <!-- Filter Bar: compact single row inline -->
        <Border DockPanel.Dock="Top" Style="{DynamicResource CardBorder}" Margin="0,0,0,10" Padding="10,6">
            <WrapPanel VerticalAlignment="Center">
                <!-- Date range -->
                <TextBlock Text="기간" FontSize="19" Foreground="{DynamicResource TextMidBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding FilterStartDate}" FontSize="19" Width="180" Margin="0,0,4,0"/>
                <TextBlock Text="~" FontSize="19" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMidBrush}" Margin="4,0"/>
                <DatePicker SelectedDate="{Binding FilterEndDate}" FontSize="19" Width="180" Margin="4,0,10,0"/>

                <!-- Category checkboxes inline -->
                <TextBlock Text="구분" FontSize="19" Foreground="{DynamicResource TextMidBrush}"
                           VerticalAlignment="Center" Margin="10,0,8,0"/>
                <CheckBox Content="수유" IsChecked="{Binding FilterFeed}" FontSize="19"
                          Foreground="{DynamicResource CatFeedBrush}" Margin="0,0,18,0" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
                <CheckBox Content="배변" IsChecked="{Binding FilterBowel}" FontSize="19"
                          Foreground="{DynamicResource CatBowelBrush}" Margin="0,0,18,0" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
                <CheckBox Content="위생" IsChecked="{Binding FilterHygiene}" FontSize="19"
                          Foreground="{DynamicResource CatHygieneBrush}" Margin="0,0,18,0" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
                <CheckBox Content="신체" IsChecked="{Binding FilterBody}" FontSize="19"
                          Foreground="{DynamicResource CatBodyBrush}" Margin="0,0,18,0" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
                <CheckBox Content="건강" IsChecked="{Binding FilterHealth}" FontSize="19"
                          Foreground="{DynamicResource CatHealthBrush}" Margin="0,0,18,0" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
                <CheckBox Content="기타" IsChecked="{Binding FilterEtc}" FontSize="19"
                          Foreground="{DynamicResource CatEtcBrush}" Margin="0,0,18,0" VerticalAlignment="Center" VerticalContentAlignment="Center"/>

                <!-- Search input with placeholder -->
                <Grid Margin="10,0,0,0" Height="34">
                    <TextBox x:Name="SearchBox" Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Width="250" FontSize="19" Height="34" MinHeight="34" VerticalContentAlignment="Center"
                             Foreground="{DynamicResource TextLightBrush}"
                             Background="{DynamicResource BgInputBrush}"
                             CaretBrush="{DynamicResource TextLightBrush}"/>
                    <TextBlock x:Name="SearchHint" Text="&#x1F50D; 키워드 검색..." IsHitTestVisible="False"
                               Foreground="{DynamicResource TextMidBrush}" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="19">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </WrapPanel>
        </Border>

        <!-- Pagination Bar -->
        <Border DockPanel.Dock="Bottom" Style="{DynamicResource CardBorder}" Margin="0,10,0,0" Padding="12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="&#x25C0;" Command="{Binding PrevPageCommand}"
                        Style="{DynamicResource SecondaryButton}" MinWidth="60" Height="48" FontSize="19"/>
                <TextBlock FontSize="19" VerticalAlignment="Center" Margin="16,0">
                    <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                    <Run Text="/"/>
                    <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                    <Run Text=" ("/>
                    <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                    <Run Text="건)"/>
                </TextBlock>
                <Button Content="&#x25B6;" Command="{Binding NextPageCommand}"
                        Style="{DynamicResource SecondaryButton}" MinWidth="60" Height="48" FontSize="19"/>

                <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="16,4"/>

                <Button Content="{Binding SortButtonText}" Command="{Binding ToggleSortCommand}"
                        Style="{DynamicResource SecondaryButton}" MinWidth="110" Height="48" FontSize="19" Margin="4,0"/>

                <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" Margin="16,4"/>

                <Button Content="수정" Command="{Binding EditEventCommand}" CommandParameter="{Binding SelectedEvent}"
                        Style="{DynamicResource PrimaryButton}" MinWidth="80" Height="48" FontSize="19" Margin="8,0"
                        Background="{DynamicResource CatSystemBrush}"/>
                <Button Content="삭제" Command="{Binding DeleteEventCommand}" CommandParameter="{Binding SelectedEvent}"
                        Style="{DynamicResource SecondaryButton}" MinWidth="80" Height="48" FontSize="19" Margin="4,0"/>
            </StackPanel>
        </Border>

        <!-- DataGrid: full width table -->
        <Border Style="{DynamicResource CardBorder}" Padding="0" CornerRadius="14" Margin="0">
            <DataGrid x:Name="EventGrid" ItemsSource="{Binding FilteredEvents}"
                      SelectedItem="{Binding SelectedEvent}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="44"
                      FontSize="19"
                      Background="{DynamicResource BgCardBrush}"
                      Foreground="{DynamicResource TextLightBrush}"
                      BorderThickness="0"
                      RowBackground="{DynamicResource BgCardBrush}"
                      AlternatingRowBackground="{DynamicResource BgDarkBrush}"
                      HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="일차" Binding="{Binding DayNumber}" MinWidth="70" Width="SizeToCells"/>
                    <DataGridTextColumn Header="날짜" Binding="{Binding Date, StringFormat=MM/dd}" MinWidth="80" Width="SizeToCells"/>
                    <DataGridTextColumn Header="시간" Binding="{Binding Time, StringFormat=hh\\:mm}" MinWidth="75" Width="SizeToCells"/>
                    <DataGridTextColumn Header="구분" Binding="{Binding Category}" MinWidth="90" Width="SizeToCells">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Category, Converter={StaticResource CategoryToColor}}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="19"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="세부내용" Binding="{Binding Detail}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Converter={StaticResource DetailColor}}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="19"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="양" Binding="{Binding Amount}" MinWidth="80" Width="SizeToCells"/>
                    <DataGridTextColumn Header="수유텀" Binding="{Binding FeedingInterval, Converter={StaticResource TimeSpanToString}}" MinWidth="120" Width="SizeToCells"/>
                    <DataGridTextColumn Header="비고" Binding="{Binding Note}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>

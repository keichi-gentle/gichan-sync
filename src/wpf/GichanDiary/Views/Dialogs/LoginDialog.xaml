<Window x:Class="GichanDiary.Views.Dialogs.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Firebase 로그인"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        WindowStyle="None"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="#1A1F2E" CornerRadius="12" Padding="40,32" MinWidth="480" BorderBrush="#2A3555" BorderThickness="1">
        <StackPanel>
            <!-- Title -->
            <TextBlock Text="Firebase 로그인" FontSize="28" FontWeight="Bold"
                       Foreground="#5B9BD5" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Firestore 동기화를 위해 관리자 인증이 필요합니다"
                       FontSize="15" Foreground="#8090A8"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- Form -->
            <Border Background="#141824" CornerRadius="10" Padding="20,16" Margin="0,0,0,16">
                <StackPanel>
                    <!-- Email -->
                    <TextBlock Text="이메일" FontSize="16" Foreground="#8090A8" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtEmail" FontSize="18"
                             Background="#0D1218" Foreground="#E0E0E0" BorderBrush="#2A3555"
                             Padding="8,8" VerticalContentAlignment="Center"
                             Margin="0,0,0,12"/>

                    <!-- Password -->
                    <TextBlock Text="비밀번호" FontSize="16" Foreground="#8090A8" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="TxtPassword" FontSize="18"
                                 Background="#0D1218" Foreground="#E0E0E0" BorderBrush="#2A3555"
                                 Padding="8,8" VerticalContentAlignment="Center"
                                 KeyDown="TxtPassword_KeyDown"/>

                    <!-- Status / Error message -->
                    <TextBlock x:Name="TxtStatus" Text="" FontSize="15"
                               Foreground="#E07070" TextWrapping="Wrap"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                <Button x:Name="BtnLogin" Content="로그인" Click="Login_Click"
                        MinWidth="160" Height="44" FontSize="20" FontWeight="Bold" Margin="0,0,12,0"
                        Foreground="#4EC9B0" Cursor="Hand" Padding="16,8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#1E3A2C" BorderBrush="#2A5540" BorderThickness="1"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2A5540"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#4EC9B0"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="취소" Click="Cancel_Click"
                        MinWidth="160" Height="44" FontSize="20"
                        Foreground="#A08090" Cursor="Hand" Padding="16,8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#2A2030" BorderBrush="#4A3050" BorderThickness="1"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#3A3050"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#A08090"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>

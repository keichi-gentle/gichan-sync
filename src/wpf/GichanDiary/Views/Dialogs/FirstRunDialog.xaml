<Window x:Class="GichanDiary.Views.Dialogs.FirstRunDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="아기 이벤트 일지 - 처음 설정"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        WindowStyle="None"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- 새 파일 생성 스타일 (녹색 톤) -->
        <Style x:Key="GreenDialogButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Foreground" Value="{DynamicResource CatFeedBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource BgInputBrush}" BorderBrush="{DynamicResource CatFeedBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CatFeedBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource CatFeedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 기존 파일 열기 스타일 (파란 톤) -->
        <Style x:Key="BlueDialogButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Foreground" Value="{DynamicResource CatHygieneBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource BgInputBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgSidebarActiveBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource CatHygieneBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 취소 스타일 (보라 톤) -->
        <Style x:Key="CancelDialogButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Foreground" Value="#A08090"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#2A2030" BorderBrush="#4A3050" BorderThickness="1"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3050"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#A08090"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1A1F2E" CornerRadius="12" Padding="40,32" MinWidth="520" BorderBrush="#2A3555" BorderThickness="1">
        <StackPanel>
            <!-- Title -->
            <TextBlock Text="아기 이벤트 일지" FontSize="28" FontWeight="Bold"
                       Foreground="#5B9BD5" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="처음 설정" FontSize="20" Foreground="#8090A8"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <!-- Excel File Section -->
            <Border Background="#141824" CornerRadius="10" Padding="20,16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Excel 파일 선택" FontSize="20" FontWeight="Bold"
                               Foreground="#5B9BD5" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <Button x:Name="BtnNewFile" Content="새 파일 생성" Click="NewFile_Click"
                                Style="{StaticResource GreenDialogButton}" Margin="0,0,12,0"/>
                        <Button x:Name="BtnOpenFile" Content="기존 파일 열기" Click="OpenFile_Click"
                                Style="{StaticResource BlueDialogButton}"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtFilePath" Text="파일을 선택해주세요" FontSize="17"
                               Foreground="#8090A8" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Baby Info Section -->
            <Border Background="#141824" CornerRadius="10" Padding="20,16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="아기 정보" FontSize="20" FontWeight="Bold"
                               Foreground="#5B9BD5" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="이름" FontSize="18" Foreground="#8090A8" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtBabyName" Grid.Column="1" FontSize="18"
                                 Background="#0D1218" Foreground="#E0E0E0" BorderBrush="#2A3555"
                                 Padding="8,6" VerticalContentAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="생년월일" FontSize="18" Foreground="#8090A8" VerticalAlignment="Center"/>
                        <DatePicker x:Name="DpBirthDate" Grid.Column="1" FontSize="18"
                                    Background="#0D1218" Foreground="#E0E0E0" BorderBrush="#2A3555"/>
                    </Grid>
                    <TextBlock Text="(건너뛰기 가능 - 나중에 설정에서 변경할 수 있습니다)" FontSize="15"
                               Foreground="#606878" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Start + Cancel Buttons (새 파일 생성 버튼과 완전 동일 구조) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                <Button x:Name="BtnStart" Content="시작" Click="Start_Click"
                        IsEnabled="False"
                        MinWidth="160" Height="44" FontSize="20" FontWeight="Bold" Margin="0,0,12,0"
                        Foreground="#4EC9B0" Cursor="Hand" Padding="16,8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#1E3A2C" BorderBrush="#2A5540" BorderThickness="1"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2A5540"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#4EC9B0"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="취소" Click="Cancel_ButtonClick"
                        MinWidth="160" Height="44" FontSize="20"
                        Foreground="#A08090" Cursor="Hand" Padding="16,8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#2A2030" BorderBrush="#4A3050" BorderThickness="1"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#3A3050"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#A08090"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
